{
  "expo": {
    "name": "AGASA Alert",
    "slug": "agasa-alert",
    "owner": "libreville",
    "version": "1.0.6",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "agasa-alert",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B7A1B"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "ga.agasa.alert",
      "versionCode": 6,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "AGASA Alert a besoin d'accéder à votre galerie pour ajouter des photos aux signalements.",
          "cameraPermission": "AGASA Alert a besoin d'accéder à votre caméra pour photographier les problèmes."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "AGASA Alert utilise votre localisation pour situer les signalements sur la carte."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "c694980e-8d52-4649-8a18-228fac084633"
      }
    }
  }
}
